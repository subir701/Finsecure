{"openapi":"3.1.0","info":{"title":"finSecure API","description":"Finance dashboard backend","version":"1.0"},"servers":[{"url":"http://localhost:8080","description":"Generated server url"}],"tags":[{"name":"Authentication","description":"User registration and JWT token acquisition"},{"name":"Records","description":"Financial record management (CRUD & Filtering)"},{"name":"Admin","description":"System-wide user management and role assignment (ADMIN only)"},{"name":"Dashboard","description":"Analytics and summary endpoints"}],"paths":{"/finsecure/records/{id}":{"get":{"tags":["Records"],"summary":"Get record details by ID (ADMIN, ANALYST)","description":"Fetches a single financial record using its unique UUID. Accessible only to high-privilege roles.","operationId":"getById","parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/RecordResponse"}}}}},"security":[{"bearerAuth":[]}]},"put":{"tags":["Records"],"summary":"Update an existing record (ADMIN only)","description":"Modifies the details of a specific financial record. Changes to amounts or categories are restricted to the ADMIN role.","operationId":"update","parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/RecordRequest"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/RecordResponse"}}}}},"security":[{"bearerAuth":[]}]},"delete":{"tags":["Records"],"summary":"Delete a record (ADMIN only)","description":"Permanently removes a record from the database. This action is destructive and limited to the ADMIN role.","operationId":"delete","parameters":[{"name":"id","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","conten