"Returns month-by-month income vs expense trends for the authenticated user.","operationId":"getMyTrends","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TrendResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/finsecure/dashboard/my/totals":{"get":{"tags":["Dashboard"],"summary":"My totals — income, expenses, net balance","description":"Returns financial totals scoped to the authenticated user's own records.","operationId":"getMyTotals","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TotalsResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/finsecure/dashboard/my/recent":{"get":{"tags":["Dashboard"],"summary":"My recent activity — last 10 transactions ","description":"Returns the 10 most recent records for the authenticated user.","operationId":"getMyRecentActivity","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"array","items":{"$ref":"#/components/schemas/RecordResponse"}}}}}},"security":[{"bearerAuth":[]}]}},"/finsecure/dashboard/my/categories":{"get":{"tags":["Dashboard"],"summary":"My category breakdown — income and expenses by category","description":"Returns category-wise totals scoped to the authenticated user.","operationId":"getMyCategorySummary","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/CategorySummaryResponse"}}}}},"security":[{"bearerAuth":[]}]}},"/finsecure/dashboard/global/trends":{"get":{"tags":["Dashboard"],"summary":"Global monthly trends — configurable window (ANALYST, ADMIN)","description":"Platform-wide month-by-month trends. Use ?months=6 (default) to control the lookback window.","operationId":"getGlobalTrends","parameters":[{"name":"months","in":"query","required":false,"schema":{"type":"integer","format":"int32","default":6}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/TrendResponse"}}}}},"security":[{"bearerAuth":[]}]